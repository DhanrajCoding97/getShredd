generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id               String   @id
  dailyCalorieGoal Int      @default(2000) @map("daily_calorie_goal")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  meals            Meal[]

  @@map("profiles")
}

model Meal {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  calories  Int
  proteinG  Float    @default(0) @map("protein_g")
  carbsG    Float    @default(0) @map("carbs_g")
  fatG      Float    @default(0) @map("fat_g")
  mealType  String   @default("snack") @map("meal_type")
  eatenAt   DateTime @default(now()) @map("eaten_at")
  createdAt DateTime @default(now()) @map("created_at")
  profile   Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meals")
}