generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id               String   @id
  name             String?
  age              Int?
  weight           Float?
  weightUnit       String   @default("kg") @map("weight_unit")
  height           Float?
  heightUnit       String   @default("cm") @map("height_unit")
  gender           String?
  activityLevel    String   @default("moderate") @map("activity_level")
  goal             String   @default("maintain") @map("goal")
  dailyCalorieGoal Int      @default(2000) @map("daily_calorie_goal")
  dailyProteinGoal Int      @default(150) @map("daily_protein_goal")
  dailyCarbsGoal   Int      @default(200) @map("daily_carbs_goal")
  dailyFatGoal     Int      @default(65) @map("daily_fat_goal")
  onboarded        Boolean  @default(false)
  updatedAt        DateTime @updatedAt @map("updated_at")
  meals            Meal[]

  @@map("profiles")
}

model Meal {
  id     String @id @default(uuid())
  userId String @map("user_id")
  name   String

  calories Int
  proteinG Float @default(0) @map("protein_g")
  carbsG   Float @default(0) @map("carbs_g")
  fatG     Float @default(0) @map("fat_g")

  mealType MealType

  eatenAt   DateTime @default(now()) @map("eaten_at")
  createdAt DateTime @default(now()) @map("created_at")
  profile   Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meals")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}
